# =============================================
# GitHub Contributor Bot - Environment Variables
# =============================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control!

# ----------------------------
# GitHub Configuration
# ----------------------------
# Personal Access Token with scopes: repo, read:user, workflow
GITHUB_TOKEN=ghp_your_personal_access_token_here

# Your GitHub bot/personal username
GITHUB_USERNAME=your_github_username

# ----------------------------
# AI Provider Configuration
# ----------------------------
# OpenAI API Key (used when ai.provider = "openai" in config.yaml)
OPENAI_API_KEY=sk-your_openai_api_key_here

# Anthropic API Key (used when ai.provider = "anthropic" in config.yaml)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# ----------------------------
# Optional Overrides
# ----------------------------
# Override config.yaml settings at runtime
# BOT_MAX_PRS_PER_DAY=3
# BOT_MIN_CONFIDENCE_SCORE=0.7
# AI_MODEL=gpt-4o
# LOG_LEVEL=INFO
